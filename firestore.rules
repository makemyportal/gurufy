rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ----------------------------------------------------
    // COMMON FUNCTIONS
    // ----------------------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isAdmin() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return role == 'admin' || role == 'superadmin';
    }

    function isParticipant(participantsArray) {
      return request.auth.uid in participantsArray;
    }

    // ----------------------------------------------------
    // USER DATA (users, teachers, schools)
    // ----------------------------------------------------
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow creation if they match the ID. Allow updates if it's their ID or admin.
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) || isAdmin();

      // AI Generation History — private to each user
      match /generations/{genId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    match /teachers/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) || isAdmin();
    }
    
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ----------------------------------------------------
    // SOCIAL CONTENT (posts, comments)
    // ----------------------------------------------------
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
      
      match /comments/{commentId} {
        allow read: if true;
        // Here we assume comment doc has authorId
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    // ----------------------------------------------------
    // CONTENT HUBS (resources, events, audioRooms, jobs, groups)
    // ----------------------------------------------------
    match /resources/{resourceId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Allow updates to 'downloads' counter via array-remove/increment, but restrict full edit to owner
      allow update: if isAuthenticated(); // Broad update for download tallying, ideally restrict specific fields
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school';
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /applications/{appId} {
      // Only applicant and job poster can read applications
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.applicantId || request.auth.uid == resource.data.schoolId || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.applicantId || isAdmin());
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isParticipant(resource.data.members) || isAdmin();
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.creatorId || isAdmin());

      match /discussions/{discussionId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isParticipant(get(/databases/$(database)/documents/groups/$(groupId)).data.members);
        allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Assume creatorId field exists
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.creatorId || isAdmin());
    }

    match /timetables/{timetableId} {
      // Allow users to read their own timetables or admin
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /audioRooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.hostId || isAdmin());
    }

    match /marketplace/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.sellerId || isAdmin());
    }

    match /mentorship/{mentorId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.mentorId || isAdmin());
    }

    // ----------------------------------------------------
    // PRIVATE / SYSTEM DATA
    // ----------------------------------------------------
    match /conversations/{conversationId} {
      // Only allow participants to read conversation metadata
      allow read: if isAuthenticated() && isParticipant(resource.data.participants);
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isParticipant(resource.data.participants);

      match /messages/{messageId} {
        // Read and create messages only if part of the conversation
        allow read, create: if isAuthenticated() && isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
        allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.senderId;
      }
    }

    // Proper nested notifications block for user profile
    match /users/{userId}/notifications/{notificationId} {
       allow read: if isOwner(userId);
       // Anyone authenticated can create a notification for someone else
       allow create: if isAuthenticated(); 
       allow update, delete: if isOwner(userId);
    }

    match /gamification/{userId} {
      allow read: if true;
      // Allow authenticated users to create/update gamification score
      // Note: In production you'd use Cloud Functions to increment XP securely.
      allow create, update: if isAuthenticated(); 
      allow delete: if isAdmin();
    }
    
    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    match /userStats/{userId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /platformSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Payment requests - any logged-in user can create, admin can read/update
    match /paymentRequests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated();
    }

    // Support messages — anyone can create (logged-in users + public contact form visitors), admin manages
    match /supportMessages/{msgId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // Admin notifications - any logged-in user can create, admin can read/update
    match /adminNotifications/{notifId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Tool usage tracking
    match /tool_usage/{usageId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // User vault (document storage for Smart Exam Maker)
    match /users/{userId}/vault/{vaultId} {
      allow read, write: if isOwner(userId);
    }

    // User question bank
    match /users/{userId}/questionBank/{qbId} {
      allow read, write: if isOwner(userId);
    }
  }
}
